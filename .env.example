# ──────────────────────────────────────────────────────────────────────────────
#  AI Press Review — local .env template
#
#  Copy this file to .env (one level up if running from tools/, or in repo
#  root if running from there) and fill in your real keys. .env is gitignored
#  so your keys never get committed.
#
#  The local automation script (tools/run-podcast.command) will copy this
#  template to .env on first run and prompt you to edit it.
# ──────────────────────────────────────────────────────────────────────────────

# ── LLM (OpenRouter — recommended for one-key multi-provider) ────────────────
LLM_BASE_URL=https://openrouter.ai/api/v1
LLM_API_KEY=sk-or-v1-REPLACE_WITH_YOUR_OPENROUTER_KEY

# Generic models — used as fallback when no per-locale override is set.
LLM_EDITOR_MODEL=google/gemini-2.5-pro
LLM_FALLBACK_MODEL=google/gemini-2.5-pro

# Per-locale model overrides (recommended setup, matches the GitHub Actions
# config). EN uses Claude Sonnet 4.5 for journalism tone; FR uses Mistral
# Large 2411 for sophisticated French register. Both routed through the
# single OpenRouter key above.
LLM_EDITOR_MODEL_EN=anthropic/claude-sonnet-4.5
LLM_FALLBACK_MODEL_EN=google/gemini-2.5-pro
LLM_EDITOR_MODEL_FR=mistralai/mistral-large-2411
LLM_FALLBACK_MODEL_FR=google/gemini-2.5-pro

# Optional 3rd cascade tier — leave blank to disable.
LLM_EMERGENCY_MODEL=
LLM_EMERGENCY_MODEL_EN=
LLM_EMERGENCY_MODEL_FR=

# Optional: for truly free dry runs, point at a local Ollama server.
# Uncomment, install ollama (`brew install ollama && ollama pull qwen2.5:32b`),
# then the script's "preview" mode (with --local-preview) will use this and
# never hit the paid API.
# LOCAL_LLM_BASE_URL=http://localhost:11434/v1
# LOCAL_LLM_EDITOR_MODEL=qwen2.5:32b

# ── TTS (Cartesia) ───────────────────────────────────────────────────────────
CARTESIA_API_KEY=REPLACE_WITH_YOUR_CARTESIA_KEY
# Per-locale voice IDs — settings._apply_locale picks the right one.
CARTESIA_VOICE_ID=REPLACE_WITH_EN_VOICE_UUID
CARTESIA_VOICE_ID_FR=REPLACE_WITH_FR_VOICE_UUID

# ── Cloudflare R2 (audio hosting) ────────────────────────────────────────────
R2_BUCKET_NAME=pressreview
R2_ENDPOINT=https://YOUR-ACCOUNT-ID.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=REPLACE_WITH_R2_ACCESS_KEY
R2_SECRET_ACCESS_KEY=REPLACE_WITH_R2_SECRET_KEY

# Public URL where R2 audio is served from (CDN-fronted bucket).
PUBLIC_AUDIO_BASE_URL=https://pub-YOUR-PUBLIC-ID.r2.dev/pressreview

# ── NewsAPI (article ingestion) ──────────────────────────────────────────────
NEWSAPI_API_KEY=REPLACE_WITH_NEWSAPI_KEY

# ── Podcast metadata (mostly inherited from config/podcast.yaml) ─────────────
PODCAST_DESCRIPTION_LONG=
