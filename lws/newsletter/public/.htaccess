# /api/.htaccess — hardening for the LWS-hosted newsletter endpoints.
#
# Place this file in the same directory as subscribe.php / export.php
# (i.e. /public_html/api/.htaccess on your LWS server).

# 1. Don't expose config.php under any circumstance, even if Apache
#    momentarily forgets it's a PHP file.
<Files "config.php">
    Require all denied
</Files>
<Files "config.example.php">
    Require all denied
</Files>

# 2. Don't list the directory if no index file is present.
Options -Indexes

# 3. Default charset for any plain text that escapes (errors, etc.).
AddDefaultCharset UTF-8

# 4. Apache+FastCGI on LWS sometimes drops the Authorization header
#    on the way to PHP — re-inject it so export.php can read it via
#    $_SERVER['HTTP_AUTHORIZATION'].
RewriteEngine On
RewriteCond %{HTTP:Authorization} ^(.+)$
RewriteRule .* - [E=HTTP_AUTHORIZATION:%1]

# 5. Mild defense-in-depth headers. Doesn't replace the per-script
#    Cache-Control / X-Content-Type-Options headers, just adds a
#    blanket fallback.
<IfModule mod_headers.c>
    Header always set X-Content-Type-Options "nosniff"
    Header always set Referrer-Policy "strict-origin-when-cross-origin"
</IfModule>
